-- ============================================================
-- UTILITIES
-- ============================================================
local function Tw(obj, props, t, sty, dir)
    TweenService:Create(obj,
        TweenInfo.new(t or 0.25, sty or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
        props):Play()
end

local function Cr(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 10)
    c.Parent = p
end

local function St(p, col, th, tr)
    local s = Instance.new("UIStroke")
    s.Color       = col or T.Border
    s.Thickness   = th  or 1.5
    s.Transparency= tr  or 0
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = p
    return s
end

local function Gr(p, rot, seq)
    local g = Instance.new("UIGradient")
    g.Rotation = rot or 0
    g.Color    = seq or ColorSequence.new({
        ColorSequenceKeypoint.new(0, T.PrimaryLight),
        ColorSequenceKeypoint.new(1, T.PrimaryDark),
    })
    g.Parent = p
end

local function Lbl(parent, text, font, size, color, ax, zi, sx, sy, px, py)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Text   = text
    l.Font   = font  or Enum.Font.Gotham
    l.TextSize = size or 13
    l.TextColor3 = color or T.Text
    l.TextXAlignment = ax or Enum.TextXAlignment.Left
    l.Size   = UDim2.new(sx or 1, 0, sy or 1, 0)
    l.Position = UDim2.new(px or 0, 0, py or 0, 0)
    l.ZIndex = zi or 12
    l.Parent = parent
    return l
end

