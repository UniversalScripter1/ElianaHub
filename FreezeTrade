-- DROPDOWN LOGIC
-- ============================================================
local selPlayer = nil
local ddOpen    = false

local function DDClose()
    ddOpen = false
    Tw(DDList, {Size = UDim2.new(1, 0, 0, 0)}, 0.2)
    task.delay(0.21, function() DDList.Visible = false end)
end

local function DDOpen()
    ddOpen = true
    DDList.Visible = true
    local cnt = #Players:GetPlayers()
    local h   = math.min(cnt * 34 + 6, 148)
    Tw(DDList, {Size = UDim2.new(1, 0, 0, h)}, 0.2)
    DDScroll.CanvasSize = UDim2.new(0, 0, 0, DDLayout.AbsoluteContentSize.Y + 6)
end

local function DDPopulate()
    for _, c in pairs(DDScroll:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    for _, plr in ipairs(Players:GetPlayers()) do
        local btn = Instance.new("TextButton")
        btn.Name             = plr.Name
        btn.Size             = UDim2.new(1, 0, 0, 30)
        btn.BackgroundColor3 = T.SurfaceHov
        btn.BackgroundTransparency = 1
        btn.Text             = ""
        btn.ZIndex           = 24
        btn.Parent           = DDScroll
        Cr(btn, 7)

        local mBg = Instance.new("Frame")
        mBg.Size            = UDim2.new(0, 22, 0, 22)
        mBg.Position        = UDim2.new(0, 4, 0.5, -11)
        mBg.BackgroundColor3= T.PrimaryDark
        mBg.BorderSizePixel = 0
        mBg.ZIndex          = 25
        mBg.Parent          = btn
        Cr(mBg, 6)

        local mIco = Instance.new("ImageLabel")
        mIco.Size               = UDim2.new(1, 0, 1, 0)
        mIco.BackgroundTransparency = 1
        mIco.ZIndex             = 26
        mIco.ScaleType          = Enum.ScaleType.Crop
        mIco.Parent             = mBg
        Cr(mIco, 6)
        pcall(function()
            mIco.Image = Players:GetUserThumbnailAsync(plr.UserId,
                Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
        end)

        local nLbl = Lbl(btn, plr.Name, Enum.Font.GothamSemibold, 12, T.Text,
            Enum.TextXAlignment.Left, 25)
        nLbl.Size     = UDim2.new(1, -32, 1, 0)
        nLbl.Position = UDim2.new(0, 30, 0, 0)

        btn.MouseEnter:Connect(function() Tw(btn, {BackgroundTransparency = 0}, 0.1) end)
        btn.MouseLeave:Connect(function() Tw(btn, {BackgroundTransparency = 1}, 0.1) end)
        btn.MouseButton1Click:Connect(function()
            selPlayer         = plr
            DDBtn.Text        = plr.Name
            DDBtn.TextColor3  = T.Text
            pcall(function()
                local img = Players:GetUserThumbnailAsync(plr.UserId,
                    Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
                DDIcon.Image        = img
                DDPlaceholder.Visible = false
            end)
            SyncCard(plr)
            DDClose()
        end)
    end
    DDScroll.CanvasSize = UDim2.new(0, 0, 0, DDLayout.AbsoluteContentSize.Y + 6)
end

DDBtn.MouseButton1Click:Connect(function()
    DDPopulate()
    if ddOpen then DDClose() else DDOpen() end
end)
Players.PlayerAdded:Connect(function()
    if ddOpen then DDPopulate() end
end)
Players.PlayerRemoving:Connect(function(plr)
    if selPlayer == plr then
        selPlayer = nil
        DDBtn.Text        = "Select a player..."
        DDBtn.TextColor3  = T.TextMuted
        DDIcon.Image      = ""
        DDPlaceholder.Visible = true
        SyncCard(nil)
    end
    if ddOpen then DDPopulate() end
end)

-- ============================================================
-- FREEZE LOGIC
-- ============================================================
local freezing    = false
local shimmerConn = nil

local function ShimmerOn()
    if shimmerConn then shimmerConn:Disconnect() end
    local t = 0
    shimmerConn = RunService.Heartbeat:Connect(function(dt)
        t = t + dt * 0.7
        BarShimmer.Position = UDim2.new((t % 1.4) - 0.12, 0, 0, 0)
    end)
end

local function ShimmerOff()
    if shimmerConn then shimmerConn:Disconnect(); shimmerConn = nil end
end

FreezeBtn.MouseEnter:Connect(function()
    if not freezing then
        Tw(FBF, {BackgroundColor3 = T.PrimaryLight}, 0.15)
        Tw(FBStroke, {Transparency = 0}, 0.15)
    end
end)
FreezeBtn.MouseLeave:Connect(function()
    if not freezing then
        Tw(FBF, {BackgroundColor3 = T.Primary}, 0.15)
        Tw(FBStroke, {Transparency = 0.3}, 0.15)
    end
end)

FreezeBtn.MouseButton1Click:Connect(function()
    if freezing then return end

    if not selPlayer then
        for i = 1, 6 do
            Tw(DD, {Position = UDim2.new(0, (i % 2 == 0 and -5 or 5), 0, 18)}, 0.04)
            task.wait(0.045)
        end
        Tw(DD, {Position = UDim2.new(0, 0, 0, 18)}, 0.08)
        SetStatus("!", T.Warning,
            "No player selected. Choose a player first.",
            T.Warning, T.Warning, true)
        task.delay(3, function()
            SetStatus("i", T.Accent,
                "Select a player and press Freeze Trade.",
                T.TextDim, nil, false)
        end)
        return
    end

    freezing = true
    FreezeBtn.Active = false
    FBTitle.Text = "FREEZING..."
    FBSub.Text   = "Please wait 5 seconds..."
    FBIcon.Text  = "o"
    Tw(FBF, {BackgroundColor3 = T.PrimaryDark}, 0.25)
    SetStatus("~", T.Accent,
        "Freezing trade for " .. selPlayer.Name .. "...",
        T.TextDim, T.BorderLight, true)

    BarPct.Text      = "0%"
    BarPct.TextColor3= T.Accent
    BarFill.Size     = UDim2.new(0, 0, 1, 0)
    ShimmerOn()

    local STEPS  = 100
    local STEP_T = 5 / STEPS
    for i = 1, STEPS do
        local pct = i / STEPS
        Tw(BarFill, {Size = UDim2.new(pct, 0, 1, 0)}, STEP_T, Enum.EasingStyle.Linear)
        BarPct.Text = math.floor(pct * 100) .. "%"
        task.wait(STEP_T)
    end

    ShimmerOff()
    BarFill.Size      = UDim2.new(1, 0, 1, 0)
    BarPct.Text       = "FROZEN"
    BarPct.TextColor3 = T.Success

    Tw(BarFill, {BackgroundColor3 = T.Success}, 0.28)
    task.delay(0.5, function() Tw(BarFill, {BackgroundColor3 = T.BarFill}, 0.45) end)

    FBTitle.Text = "FREEZE TRADE"
    FBSub.Text   = "Trade has been frozen successfully!"
    FBIcon.Text  = "*"
    Tw(FBF, {BackgroundColor3 = T.SuccGreen}, 0.35)
    SetStatus("+", T.Success,
        "Trade has been frozen! Remove your offers now!",
        T.Success, T.Success, true)

    for _ = 1, 3 do
        Tw(FBStroke, {Transparency = 0}, 0.18)
        task.wait(0.22)
        Tw(FBStroke, {Transparency = 0.6}, 0.18)
        task.wait(0.22)
    end

    task.delay(2, function()
        freezing = false
        FreezeBtn.Active = true
        Tw(FBF, {BackgroundColor3 = T.Primary}, 0.35)
        FBTitle.Text = "FREEZE TRADE"
        FBSub.Text   = "Click to freeze selected player's trade"
        FBIcon.Text  = "*"
        BarPct.Text       = "IDLE"
        BarPct.TextColor3 = T.TextMuted
        Tw(BarFill, {Size = UDim2.new(0, 0, 1, 0)}, 0.45)
        task.delay(0.5, function()
            SetStatus("i", T.Accent,
                "Select a player and press Freeze Trade.",
                T.TextDim, nil, false)
        end)
    end)
end)

