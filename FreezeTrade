local function SetStatus(icon, iCol, msg, mCol, sCol, show)
    SBox.BackgroundTransparency = show and 0 or 1
    SIcon.Text       = icon
    SIcon.TextColor3 = iCol
    SMsg.Text        = msg
    SMsg.TextColor3  = mCol
    if SBoxStroke then SBoxStroke:Destroy(); SBoxStroke = nil end
    if sCol then SBoxStroke = St(SBox, sCol, 1.5) end
end

