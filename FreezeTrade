local function SyncCard(plr)
    if plr then
        CardName.Text      = plr.Name
        CardName.TextColor3= T.Text
        pcall(function()
            local img = Players:GetUserThumbnailAsync(plr.UserId,
                Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
            CardIcon.Image        = img
            CardIconPH.Visible    = false
        end)
        CardStatusF.BackgroundColor3 = Color3.fromRGB(14, 38, 20)
        CardDot.BackgroundColor3     = Color3.fromRGB(75, 195, 95)
        CardStatusTxt.Text           = "In Game"
        CardStatusTxt.TextColor3     = Color3.fromRGB(95, 225, 115)
    else
        CardName.Text      = "No player selected"
        CardName.TextColor3= T.TextMuted
        CardIcon.Image     = ""
        CardIconPH.Visible = true
        CardStatusF.BackgroundColor3 = Color3.fromRGB(40, 20, 20)
        CardDot.BackgroundColor3     = T.ErrRed
        CardStatusTxt.Text           = "None"
        CardStatusTxt.TextColor3     = T.ErrRed
    end
end

